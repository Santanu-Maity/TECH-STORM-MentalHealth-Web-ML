# ─── Flask ───────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-me

# ─── Database ─────────────────────────────────────────────
# For development (SQLite):
DEV_DATABASE_URL=sqlite:///dev_mentalhealth.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/mentalhealth_db

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-me

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email (Gmail SMTP example) ───────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ─── ML Model ─────────────────────────────────────────────
ML_MODEL_PATH=ml_model/mental_health_model.pkl
ML_SCALER_PATH=ml_model/scaler.pkl

# ─── Emergency ────────────────────────────────────────────
EMERGENCY_CONTACT_EMAIL=admin@yourdomain.com
RISK_SCORE_THRESHOLD=30
